@model ZavaStorefront.Models.ChatViewModel
@{
    ViewData["Title"] = "Chat with Phi-4";
}

<div class="container mt-4">
    <h1 class="mb-1">Chat with Phi-4</h1>
    <p class="text-muted mb-4">Ask anything — powered by Microsoft Foundry Phi-4.</p>

    <div class="row">
        <div class="col-lg-8">

            @* Input form *@
            <form asp-controller="Chat" asp-action="Send" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label for="userMessage" class="form-label fw-semibold">Your message</label>
                    <textarea id="userMessage"
                              name="userMessage"
                              class="form-control"
                              rows="4"
                              placeholder="Type your message here…"
                              maxlength="4000">@Model.UserMessage</textarea>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-warning" role="alert">
                        @Html.ValidationSummary(false)
                    </div>
                }

                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send me-1"></i> Send
                </button>
            </form>

            @* Response area — visible once a response is available *@
            @if (Model.Response != null)
            {
                <div class="mt-4">
                    <label for="responseArea" class="form-label fw-semibold">Phi-4 response</label>
                    <textarea id="responseArea"
                              class="form-control"
                              rows="10"
                              readonly>@Model.Response</textarea>
                </div>
            }

        </div>
    </div>
</div>
